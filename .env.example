# Environment variables for [Project Name]
# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# Required vars are marked REQUIRED. Optional vars have a default noted in the comment.

# --- AI / LLM ---
# REQUIRED — Anthropic API key (must be a zero-retention org key for client data)
ANTHROPIC_API_KEY=

# Optional — default model. Defaults to claude-opus-4-7 if unset.
ANTHROPIC_MODEL=

# --- Database ---
# REQUIRED — connection string for the primary database
DATABASE_URL=

# --- Auth ---
# REQUIRED — secret used to sign sessions / JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET=

# --- External services ---
# Optional — Sentry DSN for error reporting
SENTRY_DSN=

# --- App config ---
# Optional — http port. Defaults to 3000.
PORT=

# Optional — log level: debug | info | warn | error. Defaults to info.
LOG_LEVEL=
